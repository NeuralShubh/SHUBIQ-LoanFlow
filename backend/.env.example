NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
JWT_SECRET=replace-with-strong-random-32-plus-char-secret
FRONTEND_URL=https://yourdomain.com
FRONTEND_URLS=https://yourdomain.com,https://www.yourdomain.com
DB_CONNECT_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=5000
OVERDUE_SYNC_INTERVAL_MS=60000
LOGIN_WINDOW_MS=900000
LOGIN_MAX_ATTEMPTS=10
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@loanflow.com
ADMIN_PASSWORD=LoanFlow@2026#Admin
DEMO_STAFF_PASSWORD=change-this-before-running-demo-seed
