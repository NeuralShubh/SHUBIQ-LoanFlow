{
    "name":  "loanflow-frontend",
    "version":  "0.1.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "dev:clean":  "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$p=(netstat -ano | Select-String \u0027:3000\\s+.*LISTENING\\s+(\\\\d+)\u0027 | ForEach-Object { [regex]::Match($_.ToString(),\u0027LISTENING\\s+(\\\\d+)\u0027).Groups[1].Value } | Select-Object -Unique); if($p){$p | ForEach-Object { taskkill /PID $_ /F | Out-Null }}; if(Test-Path .next){Remove-Item -Recurse -Force .next}; npm run dev\"",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "next lint"
                },
    "dependencies":  {
                         "next":  "16.1.6",
                         "react":  "^19.2.0",
                         "react-dom":  "^19.2.0",
                         "@radix-ui/react-alert-dialog":  "^1.0.5",
                         "@radix-ui/react-avatar":  "^1.0.4",
                         "@radix-ui/react-dialog":  "^1.0.5",
                         "@radix-ui/react-dropdown-menu":  "^2.0.6",
                         "@radix-ui/react-label":  "^2.0.2",
                         "@radix-ui/react-progress":  "^1.0.3",
                         "@radix-ui/react-select":  "^2.0.0",
                         "@radix-ui/react-separator":  "^1.0.3",
                         "@radix-ui/react-slot":  "^1.0.2",
                         "@radix-ui/react-tabs":  "^1.0.4",
                         "@radix-ui/react-toast":  "^1.1.5",
                         "chart.js":  "^4.4.2",
                         "react-chartjs-2":  "^5.2.0",
                         "class-variance-authority":  "^0.7.0",
                         "clsx":  "^2.1.0",
                         "lucide-react":  "^0.577.0",
                         "tailwind-merge":  "^2.2.1",
                         "tailwindcss-animate":  "^1.0.7",
                         "axios":  "^1.6.7",
                         "date-fns":  "^3.3.1",
                         "zustand":  "^4.5.1"
                     },
    "devDependencies":  {
                            "typescript":  "^5",
                            "@types/node":  "^20",
                            "@types/react":  "^19",
                            "@types/react-dom":  "^19",
                            "autoprefixer":  "^10.0.1",
                            "postcss":  "^8",
                            "tailwindcss":  "^3.3.0",
                            "eslint":  "^9.39.4",
                            "eslint-config-next":  "16.1.6"
                        }
}
